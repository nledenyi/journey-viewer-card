# Copy this file to .env.local (auto-gitignored) and fill in your values.
# Used by the Vite dev harness in dev/main.ts and by the maintainer deploy
# script (scripts/deploy-to-ha.sh, resource cache-bust step). The production
# card reads from hass.states and never touches these.
#
# DEV_HA_URL: base URL of your Home Assistant instance.
# DEV_HA_TOKEN: a long-lived access token. Create at:
#   <your-ha>/profile -> Long-Lived Access Tokens -> Create Token
DEV_HA_URL=http://homeassistant.local:8123
DEV_HA_TOKEN=
